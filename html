<!DOCTYPE html> <!-- Define o tipo do documento -->
<html lang="pt-br"> <!-- Define o idioma -->

<head>
    <meta charset="UTF-8"> <!-- Permite acentos -->
    <title>Validação de Números</title>

    <!-- Importa o CSS externo -->
    <link rel="stylesheet" href="styles.css">
</head>

<body>

    <!-- Container principal que agrupa todo o conteúdo -->
    <div class="container">

        <!-- Título da aplicação -->
        <h1>Validação de Números</h1>

        <!-- Campo onde o usuário digita um número -->
        <input type="number" id="numero" placeholder="Digite um número">

        <!-- Botão que executa a função JS -->
        <button onclick="validarNumero()">Validar</button>

        <!-- Área onde será exibida a resposta -->
        <p id="mensagem"></p>

    </div>

    <!-- Importa o JavaScript -->
    <script src="script.js"></script>

</body>
</html>
